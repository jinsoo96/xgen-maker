# XGEN MAKER 자격/엔드포인트 — 이 파일을 .env로 복사해 값을 채우면 maker가 자동 로드한다.
# .env는 gitignore돼 커밋되지 않음. 여기 값은 전부 예시(placeholder) — 실제 값은 각자 채운다.
# ※ 실제 도메인·호스트·토큰은 절대 이 예시 파일에 넣지 말 것(공개 안전).

# ── GitLab (push·MR) ──
XGEN_MAKER_GITLAB_URL=https://gitlab.your-company.com
XGEN_MAKER_GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx     # 개인 액세스 토큰(PAT)
# MAKER가 작업 대상 레포에 커밋할 때 강제할 저자(대상 레포 git config 무시). 미설정 시 대상 레포 설정 사용.
XGEN_MAKER_GIT_AUTHOR_NAME=Your Name
XGEN_MAKER_GIT_AUTHOR_EMAIL=you@your-company.com

# ── LLM (판단·요약·비전 + 엔진 풀 파이프라인 provider) ──
# claude CLI 구독 로그인만 있으면 키 없이 동작(maker login). 아래 키는 선택.
# ※ 실제 키는 여기(로컬 .env)에만 — 공개 .env.example엔 placeholder만. .env는 gitignore됨.
# maker engine run --full(엔진 풀 파이프라인)은: 아래 키가 있으면 직접 API로,
# 없으면 claude 구독(CLI)으로 LLM 스테이지를 돌린다.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxx
# vLLM 등 OpenAI-호환 엔드포인트(선택)
# XGEN_MAKER_LLM_BASE=http://your-llm-host:8000/v1
# XGEN_MAKER_LLM_MODEL=your-model
# XGEN_MAKER_LLM_KEY=xxxxxxxx

# ── UI/UX 검증 (로그인 후 실제 보호화면 캡처, 선택) ──
XGEN_MAKER_UI_EMAIL=you@your-company.com
XGEN_MAKER_UI_PASSWORD=xxxxxxxx

# ── 인프라 KG / 배포 검증 (선택) ──
XGEN_MAKER_INFRA_PATH=/path/to/your-infra-repo          # Helm 차트 있는 인프라 레포

# ── 릴리즈 사다리 스테이지 URL (develop→stg→main, 선택) ──
XGEN_MAKER_URL_DEV=https://dev.your-company.com
XGEN_MAKER_URL_STG=https://stg.your-company.com
XGEN_MAKER_URL_PRD=https://app.your-company.com

# ── CI/CD 관측 (read-only — MAKER는 배포/빌드 트리거 안 함, 선택) ──
XGEN_MAKER_JENKINS_URL=https://jenkins.your-company.com
XGEN_MAKER_JENKINS_USER=you
XGEN_MAKER_JENKINS_TOKEN=xxxxxxxx
# job명→env 매핑(선택, 미설정 시 job명의 dev/stage/prd 토큰으로 추론)
# XGEN_MAKER_JENKINS_JOBMAP={"my-dev-job":"dev","my-stage-job":"stg","my-prod-job":"prd"}
XGEN_MAKER_JENKINS_DEV=my-dev-job
XGEN_MAKER_JENKINS_STG=my-stage-job
XGEN_MAKER_JENKINS_PRD=my-prod-job
XGEN_MAKER_ARGOCD_URL=https://argocd.your-company.com
XGEN_MAKER_ARGOCD_USER=you
XGEN_MAKER_ARGOCD_PASSWORD=xxxxxxxx

# ── 배포 live 인터록(기본 미설정=안전, MAKER는 MR까지만이라 보통 불필요) ──
# XGEN_MAKER_DEPLOY_LIVE=1

# ── 웹 UI 원격 노출 옵트인(기본 미설정=loopback만) ──
# 웹 대시보드는 인증이 없어 포트 접근자가 운영자 신원으로 act(push/MR)할 수 있음.
# --host 0.0.0.0 등 비-loopback 바인드는 신뢰망에서만 아래를 명시해야 허용됨.
# XGEN_MAKER_WEB_ALLOW_REMOTE=1
