# XGEN MAKER 자격 — 이 파일을 .env로 복사해 값을 채우면 maker가 자동 로드한다.
# .env는 gitignore돼 커밋되지 않음. 이미 설정된 실제 환경변수가 있으면 그게 우선.

# GitLab push·MR 토큰 (PAT) — 한 번 넣으면 재입력 불필요
XGEN_MAKER_GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# 비전 판정(UI/UX)·LLM 폴백용 Anthropic 키 (선택 — 없으면 claude_cli 로그인 사용)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# vLLM 등 OpenAI-호환 엔드포인트 (선택)
# XGEN_MAKER_LLM_BASE=http://127.0.0.1:10051/v1
# XGEN_MAKER_LLM_MODEL=Qwen3.6-27B
# XGEN_MAKER_LLM_KEY=

# 배포 live 인터록 해제(1일 때만 실제 배포 트리거) — 기본 미설정(안전)
# XGEN_MAKER_DEPLOY_LIVE=1

# Jenkins CI (read-only 상태/로그 보기 전용 — MAKER는 빌드 트리거 안 함)
XGEN_MAKER_JENKINS_URL=https://jenkins.example.com
XGEN_MAKER_JENKINS_USER=admin
XGEN_MAKER_JENKINS_TOKEN=xxxxxxxx

# ArgoCD (read-only 배포 상태 보기 전용 — sync는 사용자 수동)
XGEN_MAKER_ARGOCD_URL=https://argocd.example.com
XGEN_MAKER_ARGOCD_USER=admin
XGEN_MAKER_ARGOCD_TOKEN=xxxxxxxx

# 릴리즈 사다리 스테이지 도메인 (dev→stg→prd)
XGEN_MAKER_URL_DEV=https://dev.example.com
XGEN_MAKER_URL_STG=https://stg.example.com
XGEN_MAKER_URL_PRD=https://app.example.com

# UI/UX 검증 인증 세션 (로그인 후 실제 보호화면 캡처) — 없으면 미인증 화면만
XGEN_MAKER_UI_EMAIL=admin@example.com
XGEN_MAKER_UI_PASSWORD=xxxxxxxx
