{
  "_comment": "이 파일을 maker.config.json으로 복사해 실제 값을 채운다. maker.config.json은 gitignore됨.",
  "repos": {
    "backend-core": "/path/to/backend-core",
    "backend-workflow": "/path/to/backend-workflow",
    "frontend": "/path/to/frontend"
  },
  "gitlab_projects": {
    "backend-core": "your-group/backend-core",
    "backend-workflow": "your-group/backend-workflow",
    "frontend": "your-group/frontend"
  },
  "kg_path": "kg/merged.json",
  "mode": "observe",
  "allow_write": false,
  "theta": 0.7,
  "max_iterations": 3,
  "strict_regression": false,
  "target_branch": "develop",
  "fetch_latest": true,
  "isolate_worktree": false,
  "llm_enabled": true,
  "gitlab_url": "https://gitlab.your-company.com",
  "enable_verify": false,
  "enable_ui_verify": false,
  "enable_deploy_test": false,
  "deploy_mode": "off",
  "preview_base": "",
  "infra_path": "",
  "default_repo": "",
  "deploy_app_map": {
    "_comment": "레포명 → Helm 앱명(조직 서비스명은 여기 로컬 config에만). 예: frontend 스코프 여러 개를 앱 하나로 수렴",
    "frontend-app": "frontend",
    "frontend-features": "frontend"
  },
  "stack_profile_map": {
    "_comment": "레포명 → 로컬 스택 프로파일(선택). 미설정 시 레포명 그대로 사용",
    "frontend": "web"
  },
  "worklogs_dir": "worklogs",
  "learnings_dir": "learnings"
}
